rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function participantPath(roomId, userId) {
      return /databases/$(database)/documents/rooms/$(roomId)/participants/$(userId);
    }

    function roomExists(roomId) {
      return exists(roomPath(roomId));
    }

    function roomData(roomId) {
      return get(roomPath(roomId)).data;
    }

    function isSixDigitCode(roomId) {
      return roomId.matches('^[0-9]{6}$');
    }

    function isHost(roomId) {
      return isSignedIn() && roomExists(roomId) && roomData(roomId).hostId == request.auth.uid;
    }

    function isParticipant(roomId) {
      return isSignedIn() && exists(participantPath(roomId, request.auth.uid));
    }

    function isRoomMember(roomId) {
      return isHost(roomId) || isParticipant(roomId);
    }

    function roomIsExpiredData(data) {
      return !data.keys().hasAll(['expiresAt']) || data.expiresAt <= request.time;
    }

    function roomIsJoinable(roomId) {
      return roomExists(roomId)
        && roomData(roomId).status == 'open'
        && !roomIsExpiredData(roomData(roomId));
    }

    function validRoomShape(roomId) {
      return request.resource.data.keys().hasOnly([
          'hostId',
          'code',
          'status',
          'createdAt',
          'updatedAt',
          'expiresAt',
          'currentRoundId',
          'playlistId',
          'playlistName'
        ])
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.code == roomId
        && isSixDigitCode(roomId)
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <= request.time + duration.value(2, 'h');
    }

    match /rooms/{roomId} {
      // Exact-code lookup is allowed, but listing all active rooms is forbidden.
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isSignedIn()
        && validRoomShape(roomId)
        && request.resource.data.status == 'open';

      // The current host can maintain the room without changing its identity or TTL.
      // A different signed-in user may only claim an already expired code, placing it
      // in resetting state while the old participants, rounds and cards are deleted.
      allow update: if (
          isHost(roomId)
          && request.resource.data.hostId == resource.data.hostId
          && request.resource.data.code == resource.data.code
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.expiresAt == resource.data.expiresAt
        ) || (
          isSignedIn()
          && roomIsExpiredData(resource.data)
          && validRoomShape(roomId)
          && request.resource.data.status == 'resetting'
        );

      allow delete: if isHost(roomId);

      match /participants/{participantId} {
        allow read: if isHost(roomId) || isOwner(participantId);

        allow create: if isOwner(participantId)
          && roomIsJoinable(roomId)
          && request.resource.data.keys().hasOnly([
            'userId',
            'displayName',
            'joinedAt',
            'updatedAt',
            'active'
          ])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.active == true;

        allow update: if (isOwner(participantId) || isHost(roomId))
          && request.resource.data.userId == resource.data.userId;

        allow delete: if isOwner(participantId) || isHost(roomId);
      }

      match /rounds/{roundId} {
        allow read: if isRoomMember(roomId) && !roomIsExpiredData(roomData(roomId));
        allow create, update, delete: if isHost(roomId);

        match /cards/{cardId} {
          allow read: if (isHost(roomId) || isOwner(cardId))
            && !roomIsExpiredData(roomData(roomId));
          allow create, delete: if isHost(roomId);

          allow update: if isHost(roomId)
            || (isOwner(cardId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'markedTrackIds',
                'lineClaimedAt',
                'bingoClaimedAt',
                'updatedAt'
              ]));
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
